#!/bin/bash

APP_VERSION="1.2.1"
APP_CONF="/etc/tftpd-manager.conf"

cleanup() {
    local exit_code=$?
    
    if is_running; then
        echo -e "\n\e[33m[!] Завершение работы: остановка сервера...\e[0m"
        case_stop >/dev/null 2>&1
    fi
    
    exit $exit_code
}

trap cleanup EXIT SIGINT SIGTERM SIGHUP

if [ "$EUID" -ne 0 ]; then
    echo -e "\e[31mОшибка: Для управления TFTP требуются права суперпользователя.\e[0m"
    echo "Пожалуйста, запустите скрипт через: sudo $0"
    trap - EXIT
    exit 1
fi

BINARY=$(command -v in.tftpd || command -v tftpd || echo "/usr/sbin/in.tftpd")

if [ ! -f "$APP_CONF" ]; then
    echo 'TFTP_DIR="/var/lib/tftpboot"' > "$APP_CONF"
fi
source "$APP_CONF"

is_running() {
    pgrep -f "$BINARY" >/dev/null
}

list_files() {
    if [ -d "$TFTP_DIR" ]; then
        echo -e "\e[96mФайлы в ($TFTP_DIR):\e[0m"
        local files=$(ls -F "$TFTP_DIR" 2>/dev/null | grep -v /)
        if [ -z "$files" ]; then
            echo "  [Директория пуста]"
        else
            echo "$files" | sed 's/^/  /'
        fi
    fi
}

case_start() {
    if ! is_running; then
        [ ! -d "$TFTP_DIR" ] && mkdir -p "$TFTP_DIR" && chmod 777 "$TFTP_DIR"
        $BINARY --listen --user root --address :69 --secure --verbose "$TFTP_DIR" &
        sleep 1
    fi
}

case_stop() {
    pkill -f "$BINARY" 2>/dev/null
    sleep 0.5
}

watch_log() {
    clear
    echo -e "\e[33m--- МОНИТОРИНГ (Ctrl+C для возврата) ---\e[0m"
    trap "return" SIGINT
    journalctl -f | grep --line-buffered -E "tftpd|in.tftpd"
    trap cleanup SIGINT
}

while true; do
    clear
    echo "=========================================="
    echo "       TFTP SERVER CONTROL v$APP_VERSION"
    echo "=========================================="
    
    if is_running; then
        echo -e "Статус: \e[32mВКЛЮЧЕН\e[0m"
    else
        echo -e "Статус: \e[31mОСТАНОВЛЕН\e[0m"
    fi

    list_files
    
    echo "------------------------------------------"
    echo " 1) СТАРТ               4) ИЗМЕНИТЬ ПУТЬ"
    echo " 2) СТОП                5) МОНИТОРИНГ"
    echo " 3) ПЕРЕЗАПУСК          6) ОТКРЫТЬ В MC"
    echo "                        7) ВЫХОД"
    echo "------------------------------------------"
    read -p "Выбор: " choice

    case $choice in
        1) case_start ;;
        2) case_stop ;;
        3) case_stop; case_start ;;
        4) 
            read -e -p "Введите новый путь: " new_dir
            if [ -d "$new_dir" ]; then
                TFTP_DIR=$(realpath "$new_dir")
                echo "TFTP_DIR=\"$TFTP_DIR\"" > "$APP_CONF"
                case_stop; case_start
            else
                echo -e "\e[31mОшибка: Директория не существует\e[0m"; sleep 2
            fi ;;
        5) watch_log ;;
        6) mc "$TFTP_DIR" ;;
        7) exit 0 ;;
        *) echo -e "\e[31mНеверный выбор\e[0m"; sleep 1 ;;
    esac
done
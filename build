#!/bin/bash

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; 
BLUE='\033[0;34m'; CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'

clear

[ ! -f VERSION ] && echo "DEBUG" > VERSION
VERSION=$(cat VERSION | tr -d '[:space:]')

PKG_DIR="tftpd-manager"
SCRIPT_PATH="$PKG_DIR/usr/local/bin/tftpd-manager"
SPEC_FILE="tftpd-manager.spec"

echo -e "${BLUE}[*] Очистка старых сборок...${NC}"
rm -f *.deb *.rpm *.tar.gz

echo -e "${YELLOW}>>> Сборка версии: ${BOLD}${VERSION}${NC}\n"

echo -ne "${BLUE}[...]${NC} Обновление версии в Bash-скрипте... "
if [ -f "$SCRIPT_PATH" ]; then
    sed -i "s/^APP_VERSION=.*/APP_VERSION=\"$VERSION\"/" "$SCRIPT_PATH"
    echo -e "${GREEN}OK${NC}"
else
    echo -e "${RED}ОШИБКА: Скрипт не найден!${NC}"
    exit 1
fi

if command -v rpmbuild >/dev/null; then
    echo -e "${BLUE}[...]${NC} Запуск сборки RPM пакетов:"

    build_rpm() {
        local dist_name=$1
        local srv_dep=$2
        echo -ne "    -> Сборка для ${CYAN}${dist_name}${NC} (dep: $srv_dep)... "
        
        rpmbuild -bb \
                 --define "_version $VERSION" \
                 --define "server_dep $srv_dep" \
                 --define "_sourcedir $(pwd)/$PKG_DIR" \
                 --define "_rpmdir $(pwd)" \
                 --define "_buildrootdir $(pwd)/.rpmbuild" \
                 "$SPEC_FILE" > /dev/null 2>&1
        
        mv noarch/*.rpm "tftpd-manager-${VERSION}-${dist_name}.noarch.rpm" 2>/dev/null
        rm -rf noarch .rpmbuild
        echo -e "${GREEN}УСПЕХ${NC}"
    }

    build_rpm "alt" "tftpd"
    build_rpm "fedora" "tftp-server"
else
    echo -e "${YELLOW}[!] Пропуск RPM: установите 'rpm' и 'rpmbuild'${NC}"
fi

if command -v dpkg-deb >/dev/null; then
    echo -ne "${BLUE}[...]${NC} Сборка DEB пакета... "
    sed -i "s/^Version: .*/Version: $VERSION/" "$PKG_DIR/DEBIAN/control"
    dpkg-deb --build "$PKG_DIR" "tftpd-manager_${VERSION}_all.deb" > /dev/null
    echo -e "${GREEN}OK${NC}"
else
    echo -e "${YELLOW}[!] Пропуск DEB: dpkg-deb не найден${NC}"
fi

echo -ne "${BLUE}[...]${NC} Создание универсального архива... "
tar -czf "tftpd-manager_${VERSION}.tar.gz" -C "$PKG_DIR" usr etc 2>/dev/null || \
tar -czf "tftpd-manager_${VERSION}.tar.gz" -C "$PKG_DIR" usr
echo -e "${GREEN}OK${NC}"

ls -lh *.deb *.rpm *.tar.gz 2>/dev/null